{
  "name": "kard",
  "version": "1.0.0",
  "description": "Kard - Sistema de Gerenciamento de Atividades",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run build:clean && npm run build:ts && npm run build:css && npm run build:js",
    "build:clean": "rm -rf dist",
    "build:ts": "tsc",
    "build:css": "npx tailwindcss -i ./src/css/input.css -o ./public/css/style.css --minify && npm run minify:css",
    "build:js": "npm run minify:js",
    "minify:css": "node scripts/minify-css.js",
    "minify:js": "node scripts/minify-js.js",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "migrate": "tsx -r dotenv/config node_modules/.bin/node-pg-migrate -m src/migrations up",
    "migrate:down": "tsx -r dotenv/config node_modules/.bin/node-pg-migrate -m src/migrations down",
    "migrate:create": "tsx -r dotenv/config node_modules/.bin/node-pg-migrate -m src/migrations create",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,css,html}\"",
    "type-check": "tsc --noEmit",
    "prepare": "husky install",
    "docker:build": "docker build -t kard:latest .",
    "docker:run": "docker run -p 3000:3000 --env-file .env kard:latest",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart",
    "docker:rebuild": "docker-compose down && docker-compose build && docker-compose up -d"
  },
  "keywords": [
    "kard",
    "atividades",
    "tarefas",
    "produtividade"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
  "bcryptjs": "^2.4.3",
  "cors": "^2.8.5",
  "dotenv": "^16.4.7",
  "express": "^4.21.2",
  "express-rate-limit": "^7.5.0",
  "jsonwebtoken": "^9.0.2",
  "node-cache": "^5.1.2",
  "node-pg-migrate": "^7.8.2",
  "nodemailer": "^6.9.16",
  "pdfkit": "^0.15.0",
  "pg": "^8.13.1",
  "swagger-jsdoc": "^6.2.8",
  "swagger-ui-express": "^5.0.1",
  "validator": "^13.12.0",
  "winston": "^3.17.0",
  "winston-daily-rotate-file": "^5.0.0",
  "zod": "^3.23.8"
},
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.13.5",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "cssnano": "^7.0.6",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "terser": "^5.37.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
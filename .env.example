# ========================================
# CONFIGURAÇÕES DO BANCO DE DADOS
# ========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kard

# ========================================
# CONFIGURAÇÕES DO SERVIDOR
# ========================================
PORT=3000
NODE_ENV=development
API_VERSION=1.0.0

# ========================================
# CONFIGURAÇÕES JWT
# ========================================
JWT_SECRET=sua_chave_secreta_muito_segura_aqui_minimo_32_caracteres
JWT_REFRESH_SECRET=sua_chave_refresh_secreta_muito_segura_aqui_minimo_32_caracteres
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ========================================
# CONFIGURAÇÕES DE UPLOAD
# ========================================
MAX_FILE_SIZE=10
UPLOAD_DIR=uploads

# ========================================
# CONFIGURAÇÕES DE CACHE
# ========================================
CACHE_TTL=60000

# ========================================
# CONFIGURAÇÕES DE RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=3600000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# ========================================
# CONFIGURAÇÕES DE LOG
# ========================================
LOG_LEVEL=info

# ========================================
# CONFIGURAÇÕES DE CORS
# ========================================
CORS_ORIGIN=http://localhost:3000

# ========================================
# CONFIGURAÇÕES DE NOTIFICAÇÕES
# ========================================
NOTIFICATION_ADVANCE_TIME=30

# ========================================
# CONFIGURAÇÕES DE BACKUP
# ========================================
BACKUP_DIR=backups
BACKUP_FREQUENCY=24

# ========================================
# OUTRAS CONFIGURAÇÕES
# ========================================
ENABLE_SWAGGER_IN_PRODUCTION=false
DEBUG_SQL=false